{
  "Serilog": {
    "LevelSwitches": {
      "$controlSwitch": "Debug"
    },
    "MinimumLevel": {
      "ControlledBy": "$controlSwitch",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Level:u3} {Message:lj}{NewLine}{Exception:1}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341/",
          "apiKey": "",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "File",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} {Level:u3} {TraceId} {Message:lj}{NewLine}{Exception:1}",
          "path": "c:\\Temp\\Logs\\unitsmanagement.log",
          "rollingInterval": "Day",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "controlLevelSwitch": "$controlSwitch"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "FromGlobalLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithClientIp"
    ],
    "Properties": {
      "EnvironmentName": "Local"
    }
  },
  "DiagnosticsOptions": {
    "WarningThresholdMs": 1000
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Realm-Unit": "",
    "JJRMaster": ""
  },
  "AzureAd": {
    "TenantId": "e416ab61-afc4-415b-9a45-cec1678a0f7d",
