    "ApplicationId": "api://580bdbf7-a358-4022-8552-312bacd476f4",
    "ValidIssuers": [
      "https://login.microsoftonline.com/e416ab61-afc4-415b-9a45-cec1678a0f7d/v2.0",
      "https://sts.windows.net/e416ab61-afc4-415b-9a45-cec1678a0f7d/"
    ],
    "ValidAudiences": [
      "api://580bdbf7-a358-4022-8552-312bacd476f4",
