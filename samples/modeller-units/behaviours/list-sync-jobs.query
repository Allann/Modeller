# ListSyncJobs Query
# Retrieves a paginated list of sync jobs

query ListSyncJobs
  "Retrieves a paginated list of sync jobs with optional filtering"

  input
    PageIndex: integer, optional "Page index (0-based)"
    PageSize: integer, optional "Number of items per page"
    Status: SyncJobStatus, optional "Filter by job status"
  end

  returns many SyncJob
end

