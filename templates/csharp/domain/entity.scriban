        {{ rel | to_csharp_rel_param }}{{ end }}) =>
        (PublicId{{ for attr in entity.attributes }}, {{ attr.name | pascal_case }}{{ end }}{{ for rel in entity.relationships }}, {{ rel | to_property_name }}{{ end }}) =
        (publicId{{ for attr in entity.attributes }}, {{ attr | to_ctor_assignment }}{{ end }}{{ for rel in entity.relationships }}, {{ rel | to_tuple_value }}{{ end }});

    public Guid PublicId { get; }
{{~ for attr in entity.attributes ~}}
