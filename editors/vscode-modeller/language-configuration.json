{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(domain|entity|key|enum|flags|service|command|query|value|shared|event|projection|input|output|errors|publishes|entities|enums|services|references|attributes|identity|ownership|data|fields)\\b",
      "end": "^\\s*end\\b"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(domain|entity|key|enum|flags|service|command|query|value|shared|event|projection|input|output|errors|publishes|entities|enums|services|references|attributes|identity|ownership|data|fields)\\b.*$",
    "decreaseIndentPattern": "^\\s*end\\b"
  }
}

