{
  "name": "modeller-dsl",
  "displayName": "Modeller DSL",
  "description": "Syntax highlighting and file icons for Modeller domain definition language",
  "version": "1.4.0",
  "publisher": "catalyst",
  "engines": {
    "vscode": "^1.95.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "modeller",
    "dsl",
    "domain",
    "entity",
    "code generation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CSharp-Catalyst/Modeller"
  },
  "contributes": {
    "languages": [
      {
        "id": "modeller-def",
        "aliases": ["Modeller Domain", "def"],
        "extensions": [".def"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-entity",
        "aliases": ["Modeller Entity", "entity"],
        "extensions": [".entity"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-key",
        "aliases": ["Modeller Key", "key"],
        "extensions": [".key"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-enum",
        "aliases": ["Modeller Enum", "enum"],
        "extensions": [".enum"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-flags",
        "aliases": ["Modeller Flags", "flags"],
        "extensions": [".flags"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-service",
        "aliases": ["Modeller Service", "service"],
        "extensions": [".service"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-command",
        "aliases": ["Modeller Command", "command"],
        "extensions": [".command"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-query",
        "aliases": ["Modeller Query", "query"],
        "extensions": [".query"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-value",
        "aliases": ["Modeller Value", "value"],
        "extensions": [".value"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-shared",
        "aliases": ["Modeller Shared", "shared"],
        "extensions": [".shared"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-event",
        "aliases": ["Modeller Event", "event"],
        "extensions": [".event"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "modeller-projection",
        "aliases": ["Modeller Projection", "projection"],
        "extensions": [".projection"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "modeller-def",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-entity",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-key",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-enum",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-flags",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-service",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-command",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-query",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-value",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-shared",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-event",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      },
      {
        "language": "modeller-projection",
        "scopeName": "source.modeller",
        "path": "./syntaxes/modeller.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "modeller-icons",
        "label": "Modeller DSL Icons",
        "path": "./modeller-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^22.0.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}

